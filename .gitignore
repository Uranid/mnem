# --- local artifacts (build / scratch / dataset cache / benchmark scratch) ---
# Per-developer benchmark outputs that aren't part of the reproducibility
# fixtures in benchmarks/results/v0.1.0/. Only the locked vX.Y.Z result set ships
# with the repo. Competitor benchmark results are committed as reference.
chroma_mem0_financebench/
/datasets/
py-packages/mnem-cli/dist/
tmp_palace_src.txt

# Per-platform native artifacts staged by the release pipeline at build
# time. Source-tracked dirs ship only an empty `.gitkeep`; the actual
# binary + libonnxruntime get dropped in by `.github/workflows/release.yml`
# (binaries job) per-triple, then bundled into the wheel / npm sub-pkg.
# Never commit these by hand - they're version-, target-, and ABI-specific
# and bloat the source tree by ~70 MB per triple.
#
# File-level globs (`bin/*`, not `bin/`) because git refuses to re-include
# a tracked file (`!.gitkeep`) that lives inside an excluded directory.
# Excluding the dir outright also masks the .gitkeep allowlist, so a
# fresh `git clone` would not have the directory at all and `npm pack`
# / `python -m build` would fail at the staging step.
py-packages/mnem-cli/mnem_cli/_vendor/bin/*
py-packages/mnem-cli/mnem_cli/_vendor/lib/*
!py-packages/mnem-cli/mnem_cli/_vendor/bin/.gitkeep
!py-packages/mnem-cli/mnem_cli/_vendor/lib/.gitkeep
!py-packages/mnem-cli/mnem_cli/_vendor/.gitkeep
npm-packages/mnem-cli-*/bin/*
npm-packages/mnem-cli-*/lib/*
!npm-packages/mnem-cli-*/bin/.gitkeep
!npm-packages/mnem-cli-*/lib/.gitkeep

# Local work-in-progress directories (not project files)
.translations-wip/
